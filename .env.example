# Copy to .env and adjust for your machine. Loaded by backend/config/settings.py.
# The local defaults below work out of the box for `./dev.sh`.

# Root directory where image volumes, labels, submissions, and generated task
# files are stored. The database only stores paths relative to this root, never
# the large image data itself. Point this at your real data location.
MITO_DATA_ROOT=./data

# --- Django ----------------------------------------------------------------
DJANGO_DEBUG=true
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Browser origins allowed to call the API (the Vite dev server).
DJANGO_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Default number of z-frames per annotation task when splitting a volume.
MITO_DEFAULT_Z_STEP=16

# --- dev.sh runtime overrides (optional) -----------------------------------
# Uncomment / adjust to bind for remote or HPC access. Defaults shown.
# DJANGO_HOST=127.0.0.1
# DJANGO_PORT=8000
# VITE_HOST=127.0.0.1
# VITE_PORT=5173
# NO_BROWSER=0
