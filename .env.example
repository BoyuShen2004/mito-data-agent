# Copy to .env and adjust for your machine. Loaded by backend/config/settings.py.
# The local defaults below work out of the box for `./dev-launch.sh`.

# Root directory where image volumes, labels, submissions, and generated task
# files are stored. The database only stores paths relative to this root, never
# the large image data itself. Point this at your real data location.
MITO_DATA_ROOT=./data

# --- Django ----------------------------------------------------------------
DJANGO_DEBUG=true
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Browser origins allowed to call the API (the Vite dev server).
DJANGO_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Default number of z-frames per annotation task when splitting a volume.
MITO_DEFAULT_Z_STEP=16

# --- Modular providers (defaults shown) ------------------------------------
# Each replaceable integration is chosen by name; see progress/codemap.md.
MITO_QC_PROVIDER=basic
MITO_PROOFREADING_PROVIDER=placeholder
MITO_VISUALIZATION_PROVIDER=placeholder
MITO_PUBLISHING_PROVIDER=placeholder
# Optional external tool URLs (blank = not configured).
# MITO_PROOFREADING_TOOL_URL=
# MITO_NEUROGLANCER_BASE_URL=

# SAM2 fork-aware tracking: "local" (default) is a dependency-free CPU
# stand-in; "sam2" runs the real GPU model — only meaningful on a GPU
# compute node with requirements-sam2.txt installed (see
# progress/development.md). MITO_SAM2_ROOT/CHECKPOINT/CONFIG default (in
# config/settings.py) to the vendored copy at vendor/sam2/ — uncomment
# below only if you keep the checkout somewhere else or want a bigger/
# smaller checkpoint than the default tiny one.
# MITO_TRACKING_PROVIDER=sam2
# MITO_SAM2_ROOT=./vendor/sam2
# MITO_SAM2_CHECKPOINT=./vendor/sam2/checkpoints/sam2.1_hiera_large.pt
# MITO_SAM2_CONFIG=configs/sam2.1/sam2.1_hiera_l.yaml

# --- Processing / HPC ------------------------------------------------------
MITO_PROCESSING_BACKEND=local            # local (mock) or slurm
# MITO_SHARED_STORAGE_ROOT=/shared/mito  # defaults to MITO_DATA_ROOT
# SLURM (only used when MITO_PROCESSING_BACKEND=slurm; all lab-specific):
# MITO_SLURM_PARTITION=
# MITO_SLURM_ACCOUNT=
# MITO_SLURM_SBATCH=sbatch
# MITO_SLURM_SQUEUE=squeue
# MITO_SLURM_SACCT=sacct
# MITO_SLURM_SCANCEL=scancel

# --- dev-launch.sh runtime overrides (optional) ----------------------------
# Uncomment / adjust to bind for remote or HPC access. Defaults shown.
# DJANGO_HOST=127.0.0.1
# DJANGO_PORT=8000
# VITE_HOST=127.0.0.1
# VITE_PORT=5173
# NO_BROWSER=0
