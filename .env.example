# Copy to .env and adjust for your machine. Loaded by config/settings.py.

# Root directory on the HPC / server / lab machine where image volumes,
# labels, submissions, and generated task files are stored. The database only
# stores paths relative to this root, not the image data itself.
MITO_DATA_ROOT=/path/to/hpc/or/server/data

# Django
DJANGO_DEBUG=true
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Default number of z-frames per annotation task when splitting a volume.
MITO_DEFAULT_Z_STEP=16
