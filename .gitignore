# Django
db.sqlite3
db.sqlite3-journal
media/
staticfiles/
# Local data root (image volumes, labels, submissions live outside git)
mito_data_root/
/data/

# Vendored SAM 2 checkout + checkpoints (vendor/sam2/ — see vendor/README.md
# for provenance/how to (re)populate it). Same reasoning as /data/ above:
# large binary weights (~1.5GB) and a full third-party source tree don't
# belong in this repo's own git history. Keep vendor/README.md tracked.
vendor/*
!vendor/README.md

# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Node / frontend
node_modules/
frontend/dist/
frontend/node_modules/
frontend/.vite/
dist/

# dev.sh local state (dependency checksum markers, etc.)
.dev-cache/

# Test coverage / runtime logs / process files
coverage/
htmlcov/
.coverage
*.log
*.pid

# Environment / secrets
.env
.env.*
!.env.example
*.pem

# Per-machine agent/tool overrides (the shared .claude/ config stays tracked)
.claude/settings.local.json

# IDE
.idea/
.vscode/
*.swp
*~
